# MySQL Database Configuration
# Database name
DB_NAME=resetshop

# Database user (default: root untuk MySQL lokal)
DB_USER=root

# Database password (kosongkan kalau tidak ada password)
DB_PASSWORD=

# Database host (default: localhost)
DB_HOST=localhost

# Database port (default: 3306 untuk MySQL)
DB_PORT=3306

# JWT Secret
JWT_SECRET=rahasia_12345
